# 生产环境配置模板
# 复制为 .env.production 并填入真实值

# ============================================
# 应用配置
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# API Keys（必填）
# ============================================
APIFY_TOKEN=your_apify_token_here
# 获取：https://console.apify.com/account#/integrations

BREVO_API_KEY=your_brevo_api_key_here
# 获取：https://app.brevo.com/settings/keys/api

# ============================================
# 安全配置（必填）
# ============================================
JWT_SECRET=change_this_to_a_random_64_char_secret_key
# 生成方法：openssl rand -hex 32

# ============================================
# 公司信息
# ============================================
COMPANY_NAME=Your Company Name
TARGET_PRODUCTS=Product 1, Product 2
TARGET_COUNTRIES=United States, United Kingdom

# ============================================
# 数据库配置（可选，使用 PostgreSQL 时）
# ============================================
DB_USER=sales_user
DB_PASSWORD=change_this_secure_password
DATABASE_URL=postgresql://sales_user:change_this_secure_password@postgres:5432/cross_border_sales

# ============================================
# 域名配置（可选）
# ============================================
DOMAIN_NAME=your-domain.com
SSL_ENABLED=false

# ============================================
# 邮件配置
# ============================================
EMAIL_DAILY_LIMIT=300
EMAIL_HOURLY_LIMIT=50

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_MAX_SIZE=10M
LOG_MAX_FILES=10
