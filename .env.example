# .env.example - 环境变量模板
# 复制此文件为 .env 并填入真实值

# ============================================
# 服务器配置
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# 数据库配置
# ============================================
# SQLite (开发环境)
DATABASE_PATH=./database/dev.sqlite

# PostgreSQL (生产环境，二选一)
# DATABASE_URL=postgresql://user:password@localhost:5432/cross_border_sales

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ============================================
# Apify 配置 (线索挖掘)
# ============================================
APIFY_TOKEN=your_apify_token_here
# 获取：https://console.apify.com/account#/integrations

# ============================================
# Brevo 配置 (邮件发送)
# ============================================
BREVO_API_KEY=your_brevo_api_key_here
# 获取：https://app.brevo.com/settings/keys/api

# ============================================
# 邮件追踪域名
# ============================================
# 用于自定义追踪域名（可选，提高到达率）
TRACKING_DOMAIN=track.yourcompany.com

# ============================================
# 文件上传配置
# ============================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# WebSocket 配置
# ============================================
WS_HEARTBEAT_INTERVAL=30000

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 邮件发送限制
# ============================================
EMAIL_DAILY_LIMIT=300
EMAIL_HOURLY_LIMIT=50

# ============================================
# 公司默认配置
# ============================================
DEFAULT_COMPANY_NAME=Your Company
DEFAULT_TIMEZONE=Asia/Shanghai
