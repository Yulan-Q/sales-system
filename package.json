{
  "name": "cross-border-sales-agent",
  "version": "1.0.0",
  "description": "AI-powered sales automation for cross-border trade",
  "main": "backend/src/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && nodemon src/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "echo 'Backend does not need build'",
    "start": "node backend/src/index.js",
    "setup": "node scripts/setup.js",
    "test": "jest"
  },
  "keywords": [
    "sales",
    "automation",
    "cross-border",
    "ai",
    "email",
    "crm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "better-sqlite3": "^9.2.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.2",
    "apify-client": "^2.9.0",
    "@getbrevo/brevo": "^1.0.0",
    "node-cron": "^3.0.3",
    "ws": "^8.14.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  }
}
